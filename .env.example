# TeamSlack Environment Variables Template
# Copy to .env and fill in actual values (DO NOT commit .env file)

# ============ Slack Configuration ============
SLACK_BOT_TOKEN=xoxb_your_bot_token_here
SLACK_APP_TOKEN=xapp_your_app_token_here
SLACK_SIGNING_SECRET=your_signing_secret_here
SLACK_ORCHESTRA_CHANNEL_ID=C0123456789
# Optional: restrict slash commands to specific users or channels during testing
# SLACK_ALLOWED_USER_IDS=U0123456789,U0987654321
# SLACK_ALLOWED_CHANNEL_IDS=C0123456789,C9876543210

# ============ Jira Configuration ============
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@domain.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=TS

# ============ Database Configuration ============
DATABASE_URL=postgresql://user:password@localhost:5432/teamslack
REDIS_URL=redis://localhost:6379/0

# ============ LLM Providers ============
# Perplexity for web search and real-time data
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google Gemini for text generation and analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Model selection happens automatically based on task type in socket_mode_runner.py
DEFAULT_MODEL_PROVIDER=gemini

# ============ Application Configuration ============
APP_ENV=development
REDIS_URL=redis://localhost:6379/0

# ============ LLM Providers ============
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
DEFAULT_MODEL_PROVIDER=openai

# ============ Application Configuration ============
APP_ENV=development
APP_SECRET_KEY=your-secret-key-here-min-32-chars-recommended
BYOK_ENABLED=false

# ============ k-skill-proxy (optional, personal bot weather flow) ============
# 기상청 단기예보 + 에어코리아 조회용 hosted proxy. 쥐피티 DM 날씨 질문에서 사용.
# upstream KMA_OPEN_API_KEY 는 proxy 측에서 관리.
KSKILL_PROXY_BASE_URL=https://k-skill-proxy.nomadamas.org

# ============ Optional: Celery Configuration ============
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
